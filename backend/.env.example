# ============================================================
#  Backend Environment Variables – EXAMPLE FILE
#  Copy this file to .env and fill in your own values.
#  NEVER commit your actual .env file to version control!
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | production

# ── Database (MySQL) ─────────────────────────────────────────
DB_HOST=127.0.0.1
DB_DATABASE=fashion_shop
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here
DB_DIALECT=mysql              # mysql | sqlite

# ── JWT Authentication ───────────────────────────────────────
# Generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRATION=30d            # e.g. 1h | 7d | 30d

# ── ZaloPay Payment Integration ──────────────────────────────
# Obtain these credentials from your ZaloPay developer dashboard
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
